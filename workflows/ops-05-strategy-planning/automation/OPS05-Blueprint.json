{
  "name": "OPS05: Quality Assurance & R&D (Make.com Blueprint)",
  "flow": [
    {
      "id": 1,
      "module": "github:watchIssues",
      "version": 1,
      "parameters": {
        "label": "R&D"
      }
    },
    {
      "id": 2,
      "module": "openai:createCompletion",
      "version": 1,
      "parameters": {
        "model": "gpt-4o"
      },
      "mapper": {
        "messages": [
          {
            "role": "system",
            "content": "Evaluate benchmark outputs of new prompt structures."
          }
        ]
      }
    },
    {
      "id": 3,
      "module": "jira:createIssue",
      "version": 1,
      "parameters": {
        "project": "QA-LOGS"
      }
    }
  ]
}
