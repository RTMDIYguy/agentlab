{
  "name": "AFC01: Subscriptions (Make.com Blueprint)",
  "flow": [
    {
      "id": 1,
      "module": "stripe:watchEvents",
      "version": 1,
      "parameters": {
        "event_type": "invoice.payment_succeeded"
      }
    },
    {
      "id": 2,
      "module": "openai:createCompletion",
      "version": 1,
      "parameters": {
        "model": "gpt-4o"
      },
      "mapper": {
        "messages": [
          {
            "role": "system",
            "content": "Generate a personalized thank-you and subscription summary."
          }
        ]
      }
    },
    {
      "id": 3,
      "module": "gmail:sendEmail",
      "version": 1,
      "parameters": {
        "to": "{{1.data.object.customer_email}}"
      }
    }
  ]
}
