{
  "name": "AFC04: Communities (Make.com Blueprint)",
  "flow": [
    {
      "id": 1,
      "module": "discord:watchMessages",
      "version": 1,
      "parameters": {
        "channel": "general"
      }
    },
    {
      "id": 2,
      "module": "openai:createCompletion",
      "version": 1,
      "parameters": {
        "model": "gpt-4o"
