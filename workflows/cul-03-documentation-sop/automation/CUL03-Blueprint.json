{
  "name": "CUL03: Workflow to Platform (Make.com Blueprint)",
  "flow": [
    {
      "id": 1,
      "module": "github:watchIssues",
      "version": 1,
      "parameters": {
        "repo": "agent-lab"
      }
    },
    {
      "id": 2,
      "module": "openai:createCompletion",
      "version": 1,
      "parameters": {
        "model": "gpt-4o"
      },
      "mapper": {
        "messages": [
          {
            "role": "system",
            "content": "Map workflow requirements to specific platform integrations."
          }
        ]
      }
    },
    {
      "id": 3,
      "module": "jira:createIssue",
      "version": 1,
      "parameters": {
        "project": "PLATFORM"
      }
    }
  ]
}
